<%- include ('../Partials/HeaderRoot')  %>
        <div class="wrapper-page">

            <div class="card">
                <div class="card-body">

                    <h3 class="text-center m-0">
                        <a href="/" class="logo logo-admin">Pinly</a>
                    </h3>

                    <div class="p-3">
                        <h4 class="text-muted font-18 m-b-5 text-center">Welcome Back !</h4>
                        <p class="text-muted text-center">Sign in to continue to Pinly.</p>
                        <form class="form-horizontal m-t-30" action="/api/auth/login" method="POST">
                            <% if(error) {%> <span class="error"> <%= error %></span> <% } %>
                            <div class="form-group">
                                <label for="email">Email</label>
                                <input type="text" class="form-control<%= errors[0] && errors[0].email ? ' parsley-error' : '' %>" name="email" id="email" placeholder="Enter email">
                                <% if(errors[0] && errors[0].email) {%> <span class="error"> <%= errors[0].email %></span> <% } %>
                            </div>

                            <div class="form-group">
                                <label for="password">Password</label>
                                <input type="password" class="form-control<%= errors[0] && errors[0].password ? ' parsley-error' : '' %>" id="password" name="password" placeholder="Enter password">
                                <% if(errors[0] && errors[0].password) {%> <span class="error"> <%= errors[0].password %></span> <% } %>
                            </div>

                            <div class="form-group row m-t-20">
                                <div class="col-6">
                                    <div class="custom-control custom-checkbox">
                                        <input type="checkbox" class="custom-control-input" id="customControlInline">
                                        <label class="custom-control-label" for="customControlInline">Remember me</label>
                                    </div>
                                </div>
                                <div class="col-6 text-right">
                                    <button class="btn btn-primary w-md waves-effect waves-light" type="submit">Log In</button>
                                </div>
                            </div>

                            <div class="form-group m-t-10 mb-0 row">
                                <div class="col-12 m-t-20">
                                    <a href="/forgot" class="text-muted"><i class="mdi mdi-lock"></i> Forgot your password?</a>
                                </div>
                            </div>
                        </form>
                    </div>

                </div>
            </div>

            <!-- <div class="m-t-40 text-center">
                <p>Don't have an account ? <a href="pages-register.html" class="text-primary"> Signup Now </a> </p>
                <p>© 2018 Lexa. Crafted with <i class="mdi mdi-heart text-danger"></i> by Themesbrand</p>
            </div> -->

        </div>

        <%- include ('../Partials/FooterRoot')  %>